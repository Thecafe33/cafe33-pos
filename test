<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Cafe 33 — Menu Display</title>
    <link rel="manifest" href="/screen-manifest.json">
    <meta name="theme-color" content="#006241">
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/screen-sw.js', { scope: '/screen.html' });
      }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://www.gstatic.com/firebasejs/10.13.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.13.2/firebase-database-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.13.2/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.13.2/firebase-auth-compat.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=League+Spartan:wght@700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">

<style>
:root {
    --green: #006241;
    --green-light: #00a86b;
    --green-pale: #f0fdf4;
    --amber: #f59e0b;
    --bg: #F2F4F7;
    --panel: #ffffff;
    --panel2: #F8F9FB;
    --border: rgba(0,0,0,0.08);
    --text: #1a1a1a;
    --muted: #9ca3af;
    --card-radius: 20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
    width: 100%; height: 100%; overflow: hidden;
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    user-select: none; -webkit-user-select: none;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 4px; }

/* ── LAYOUT ── */
#root {
    display: flex;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
}

/* LEFT PANEL — Menu */
#panel-left {
    flex: 0 0 62%;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border-right: 1px solid var(--border);
    overflow: hidden;
}

/* RIGHT PANEL — Banner + Cart */
#panel-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--panel);
    overflow: hidden;
    position: relative;
}

/* ── HEADER ── */
#header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 28px;
    background: #ffffff;
    border-bottom: 1px solid var(--border);
    backdrop-filter: none;
    flex-shrink: 0;
    gap: 20px;
}
.logo-text { font-family: 'League Spartan', sans-serif; font-size: 2rem; font-weight: 900; color: var(--green); letter-spacing: -1px; line-height: 1; }
.logo-sub  { font-size: 0.65rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.15em; margin-top: 2px; }
#live-clock { font-size: 1.2rem; font-weight: 800; color: var(--muted); font-variant-numeric: tabular-nums; letter-spacing: 0.05em; }

/* ── CATEGORY TABS ── */
#cat-bar {
    display: flex;
    gap: 8px;
    padding: 12px 20px;
    overflow-x: auto;
    flex-shrink: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
}
#cat-bar::-webkit-scrollbar { display: none; }
.cat-btn {
    padding: 6px 18px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 800;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.25s;
    border: 2px solid transparent;
    background: var(--panel2);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
}
.cat-btn.active {
    background: var(--green);
    color: white;
    border-color: var(--green-light);
    box-shadow: 0 0 18px rgba(0,168,107,0.3);
}

/* ── MENU GRID ── */
#menu-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px 20px;
}
#menu-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
}
.menu-card {
    border-radius: var(--card-radius);
    overflow: hidden;
    position: relative;
    aspect-ratio: 3/4;
    cursor: default;
    transition: transform 0.3s ease;
    animation: cardIn 0.4s ease both;
}
@keyframes cardIn {
    from { opacity: 0; transform: scale(0.92) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}
.menu-card .card-img {
    width: 100%; height: 70%;
    object-fit: cover;
    display: block;
    background: #1a2a20;
}
.menu-card .card-img-placeholder {
    width: 100%; height: 70%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem;
}
.menu-card .card-body {
    padding: 8px 10px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--panel2);
    flex: 1;
}
.menu-card .card-name {
    font-size: 0.75rem;
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}
.menu-card .card-price {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--green-light);
}
/* Card no image — color card style */
.menu-card.color-card { aspect-ratio: unset; min-height: 110px; }
.menu-card.color-card .card-body {
    height: 100%;
    justify-content: center;
    background: transparent;
    padding: 12px;
}
.menu-card.color-card .card-name { font-size: 0.85rem; }
.menu-card.color-card .card-price { font-size: 0.9rem; }

/* Size badge */
.size-badge {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    background: #e5e7eb;
    color: #6b7280;
    display: inline-block;
    margin-top: 2px;
    text-transform: uppercase;
}

/* ── RIGHT: BANNER ── */
#banner-section {
    flex: 0 0 42%;
    position: relative;
    overflow: hidden;
    background: #000;
    flex-shrink: 0;
}
#banner-layer-1,
#banner-layer-2 {
    position: absolute; inset: 0;
    transition: opacity 1.2s ease-in-out;
    opacity: 0;
}
#banner-layer-1.active, #banner-layer-2.active { opacity: 1; }
#banner-layer-1 img, #banner-layer-2 img,
#banner-layer-1 video, #banner-layer-2 video {
    width: 100%; height: 100%; object-fit: cover;
}
#banner-logo-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 24px 20px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    pointer-events: none;
    z-index: 5;
}
#banner-logo-overlay p {
    color: rgba(255,255,255,0.8);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-shadow: 0 1px 6px rgba(0,0,0,0.6);
}

/* ── RIGHT: CART SECTION ── */
#cart-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--panel);
}
#cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 18px 8px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
#cart-header h2 {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
}
#cart-list-wrap {
    flex: 1;
    overflow-y: auto;
    padding: 8px 14px;
}
.cart-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 12px;
    background: var(--panel2);
    margin-bottom: 6px;
    animation: rowIn 0.25s ease both;
    border: 1px solid var(--border);
}
@keyframes rowIn { from { opacity:0; transform:translateX(12px); } to { opacity:1; transform:none; } }
.cart-qty {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #dcfce7;
    color: var(--green);
    font-weight: 900;
    font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.cart-name {
    flex: 1;
    font-size: 0.82rem;
    font-weight: 700;
    color: #1f2937;
    line-height: 1.2;
}
.cart-item-price {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--green);
    flex-shrink: 0;
}
#cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 8px;
    opacity: 0.3;
}
#cart-empty .material-symbols-outlined { font-size: 3rem; }
#cart-empty p { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }

/* ── TOTAL BAR ── */
#total-bar {
    padding: 10px 18px;
    border-top: 1px solid var(--border);
    background: var(--panel2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    gap: 12px;
}
#customer-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
}
#customer-chip .avatar {
    width: 34px; height: 34px;
    background: var(--green);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
#customer-chip .avatar .material-symbols-outlined { font-size: 1.1rem; }
#customer-chip .cust-name { font-size: 0.82rem; font-weight: 800; color: var(--green); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
#customer-chip .cust-pts { font-size: 0.6rem; font-weight: 700; color: #16a34a; text-transform: uppercase; letter-spacing: 0.08em; }
#welcome-msg {
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.3;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}
#total-right { text-align: right; flex-shrink: 0; }
#total-label { font-size: 0.6rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em; }
#total-amount { font-size: 1.9rem; font-weight: 900; color: var(--green); line-height: 1; font-variant-numeric: tabular-nums; }
#cash-info {
    display: none;
    margin-top: 4px;
    border-top: 1px dashed #e5e7eb;
    padding-top: 4px;
    gap: 8px;
    flex-direction: column;
    align-items: flex-end;
}
.cash-row { display: flex; align-items: center; gap: 8px; }
.cash-label { font-size: 0.58rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; }
#screen-paid  { font-size: 1rem; font-weight: 900; color: #1f2937; }
#screen-change { font-size: 1.3rem; font-weight: 900; color: var(--amber); }

/* ══ OVERLAYS ══ */

/* QR */
#view-qr {
    display: none;
    position: absolute; inset: 0; z-index: 60;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(24px);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    animation: fadeInUp 0.35s ease both;
}
#view-qr.active { display: flex; }
#view-qr h2 {
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--green);
}
#qr-card {
    background: #fff;
    padding: 16px;
    border-radius: 24px;
    box-shadow: 0 8px 40px rgba(0,98,65,0.18);
    border: 2px solid #e5e7eb;
}
#qr-image { width: 210px; height: 210px; object-fit: contain; border-radius: 12px; }
#qr-amount-wrap {
    text-align: center;
    background: var(--green-pale);
    border: 1px solid #bbf7d0;
    border-radius: 16px;
    padding: 10px 28px;
}
#qr-amount-label { font-size: 0.6rem; font-weight: 700; color: #166534; text-transform: uppercase; letter-spacing: 0.15em; }
#qr-amount { font-size: 2.2rem; font-weight: 900; color: var(--green); font-variant-numeric: tabular-nums; }

/* SUCCESS */
#view-success {
    display: none;
    position: absolute; inset: 0; z-index: 70;
    background: var(--green);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    animation: fadeInUp 0.3s ease both;
}
#view-success.active { display: flex; }
#view-success .material-symbols-outlined { font-size: 5rem; }
#view-success h2 { font-size: 2.2rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; }
#view-success p  { font-size: 1rem; font-weight: 600; opacity: 0.75; }

/* SCREENSAVER (full screen overlay) */
#screensaver {
    display: none;
    position: fixed; inset: 0; z-index: 100;
    background: #000;
    overflow: hidden;
}
#screensaver.active { display: block; }
#ss-layer-1, #ss-layer-2 {
    position: absolute; inset: 0;
    transition: opacity 1.2s ease-in-out;
    opacity: 0;
}
#ss-layer-1.active, #ss-layer-2.active { opacity: 1; }
#ss-layer-1 img, #ss-layer-2 img,
#ss-layer-1 video, #ss-layer-2 video {
    width: 100%; height: 100%; object-fit: cover;
}
#ss-brand {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 10;
    padding: 40px 32px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
    text-align: center;
}
#ss-brand p {
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.85);
    animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:0.7} 50%{opacity:1} }
@keyframes fadeInUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }

/* PHONE INPUT POPUP */
#view-phone {
    display: none;
    position: fixed; inset: 0; z-index: 90;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    animation: fadeInUp 0.25s ease;
}
#view-phone.active { display: flex; }
#phone-box {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 28px;
    padding: 28px;
    width: 380px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.2);
}
#phone-box h3 {
    font-size: 1rem; font-weight: 900; color: var(--green);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 18px;
}
#native-phone {
    width: 100%;
    background: #f9fafb;
    border: 2px solid #e5e7eb;
    border-radius: 16px;
    color: #1e3932;
    font-size: 2rem;
    font-weight: 900;
    text-align: center;
    padding: 14px;
    outline: none;
    letter-spacing: 0.12em;
    margin-bottom: 14px;
    transition: border-color 0.2s;
    font-family: inherit;
}
#native-phone:focus { border-color: var(--green); background: #fff; }
.phone-btns { display: flex; gap: 10px; }
.phone-btns button {
    flex: 1; padding: 12px;
    border: none; border-radius: 12px;
    font-size: 0.85rem; font-weight: 800;
    cursor: pointer; text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: opacity 0.2s;
}
.phone-btns button:active { opacity: 0.7; }
#btn-cancel-phone { background: #f3f4f6; color: #6b7280; }
#btn-submit-phone { background: var(--green); color: #fff; flex: 2; }

/* SOLD OUT badge on card */
.soldout-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(2px);
    border-radius: var(--card-radius);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    z-index: 5;
    pointer-events: none;
}
.soldout-overlay span { font-size: 1.8rem; }
.soldout-overlay p {
    font-size: 0.7rem; font-weight: 900;
    color: #fff;
    text-transform: uppercase; letter-spacing: 0.12em;
    background: rgba(239,68,68,0.85);
    padding: 3px 10px; border-radius: 6px;
}

/* Pulse dot — live indicator */
.live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green-light);
    box-shadow: 0 0 0 0 rgba(0,168,107,0.7);
    animation: livePulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
}
@keyframes livePulse {
    0%   { box-shadow: 0 0 0 0 rgba(0,168,107,0.6); }
    70%  { box-shadow: 0 0 0 7px rgba(0,168,107,0); }
    100% { box-shadow: 0 0 0 0 rgba(0,168,107,0); }
}

/* Banner slide indicator dots */
#banner-dots {
    position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%);
    display: flex; gap: 5px; z-index: 6;
}
.banner-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(255,255,255,0.35);
    transition: all 0.3s;
}
.banner-dot.active { width: 16px; border-radius: 3px; background: rgba(255,255,255,0.85); }

</style>
</head>
<body>

<div id="root">

    <!-- ══════════════════════════════════ LEFT — MENU ═══════════════════════════════ -->
    <div id="panel-left">

        <!-- Header -->
        <div id="header">
            <div>
                <div class="logo-text">The Cafe 33</div>
                <div class="logo-sub">33 xin chào · Chào mừng quý khách</div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;">
                <div class="live-dot"></div>
                <div id="live-clock">--:--</div>
            </div>
        </div>

        <!-- Category bar -->
        <div id="cat-bar"></div>

        <!-- Menu grid -->
        <div id="menu-scroll">
            <div id="menu-grid">
                <!-- filled by JS -->
            </div>
        </div>

    </div>
    <!-- ══════════════════════════════════ END LEFT ════════════════════════════════ -->

    <!-- ══════════════════════════════════ RIGHT — BANNER + CART ═════════════════════ -->
    <div id="panel-right">

        <!-- Banner slideshow -->
        <div id="banner-section">
            <div id="banner-layer-1"></div>
            <div id="banner-layer-2"></div>
            <div id="banner-logo-overlay">
                <p>The Cafe 33 — Đặt món ngay cùng nhân viên</p>
            </div>
            <div id="banner-dots"></div>
        </div>

        <!-- Cart section -->
        <div id="cart-section">
            <div id="cart-header">
                <h2>Giỏ hàng của bạn</h2>
                <div style="display:flex;align-items:center;gap:5px;opacity:0.4;">
                    <span class="material-symbols-outlined" style="font-size:1rem;">receipt_long</span>
                </div>
            </div>
            <div id="cart-list-wrap">
                <div id="cart-empty">
                    <span class="material-symbols-outlined">coffee</span>
                    <p>Chưa có món nào</p>
                </div>
                <div id="cart-list"></div>
            </div>
            <div id="total-bar">
                <div id="customer-chip">
                    <div id="welcome-msg">
                        <span class="material-symbols-outlined" style="font-size:1.1rem;">storefront</span>
                        <span>Sẵn sàng phục vụ</span>
                    </div>
                    <div id="cust-info" style="display:none;">
                        <div class="avatar"><span class="material-symbols-outlined" style="color:white;">person</span></div>
                        <div>
                            <div class="cust-name" id="cust-name">Khách</div>
                            <div class="cust-pts"><span id="cust-points">0</span> điểm tích lũy</div>
                        </div>
                    </div>
                </div>
                <div id="total-right">
                    <div id="total-label">Tổng tạm tính</div>
                    <div id="total-amount">0đ</div>
                    <div id="cash-info">
                        <div class="cash-row">
                            <span class="cash-label">Khách đưa</span>
                            <span id="screen-paid">0đ</span>
                        </div>
                        <div class="cash-row">
                            <span class="cash-label" style="color:var(--amber)">Tiền thừa</span>
                            <span id="screen-change">0đ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- QR overlay (within right panel) -->
        <div id="view-qr">
            <h2>Thanh Toán QR</h2>
            <div id="qr-card">
                <img id="qr-image" src="" alt="QR">
            </div>
            <div id="qr-amount-wrap">
                <div id="qr-amount-label">Số tiền cần thanh toán</div>
                <div id="qr-amount">0đ</div>
            </div>
        </div>

        <!-- Success overlay (within right panel) -->
        <div id="view-success">
            <span class="material-symbols-outlined">check_circle</span>
            <h2>Thành Công!</h2>
            <p>Cảm ơn quý khách đã chọn The Cafe 33</p>
        </div>

    </div>
    <!-- ══════════════════════════════════ END RIGHT ═══════════════════════════════ -->

</div><!-- #root -->

<!-- ══════════ SCREENSAVER (full screen) ══════════ -->
<div id="screensaver">
    <div id="ss-layer-1"></div>
    <div id="ss-layer-2"></div>
    <div id="ss-brand">
        <p>The Cafe 33 — Coffee &amp; More</p>
    </div>
</div>

<!-- ══════════ PHONE INPUT POPUP ══════════ -->
<div id="view-phone">
    <div id="phone-box">
        <h3>Nhập Số Điện Thoại</h3>
