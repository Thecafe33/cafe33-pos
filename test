// ── AUDIO ──────────────────────────────────────────────────────
var _audioCtx = null;
function getAudioCtx() {
    if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (_audioCtx.state === 'suspended') _audioCtx.resume();
    return _audioCtx;
}
function playJingle(type) {
    try {
        var ctx = getAudioCtx();
        var notes = type === 'success' ? [523,659,784,1047,1319]
                  : type === 'notify'  ? [784,1047,784]
                  : [784,1047,1319,1047,784];
        notes.forEach(function(freq, i){
            var osc = ctx.createOscillator(), gain = ctx.createGain();
            osc.connect(gain); gain.connect(ctx.destination);
            osc.type = 'sine';
            osc.frequency.setValueAtTime(freq, ctx.currentTime);
            var t = ctx.currentTime + i * 0.13;
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.22, t + 0.03);
            gain.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
            osc.start(t); osc.stop(t + 0.38);
        });
        setTimeout(function(){
            try {
                var c2 = getAudioCtx(), o2 = c2.createOscillator(), g2 = c2.createGain();
                o2.connect(g2); g2.connect(c2.destination);
                o2.type = 'triangle';
                o2.frequency.value = type === 'success' ? 1568 : 1047;
                g2.gain.setValueAtTime(0.18, c2.currentTime);
                g2.gain.exponentialRampToValueAtTime(0.001, c2.currentTime + 1.2);
                o2.start(c2.currentTime); o2.stop(c2.currentTime + 1.3);
            } catch(e){}
        }, notes.length * 130);
    } catch(e){ console.warn('Audio:', e); }
}
function playSound(type){ playJingle(type); }
document.addEventListener('click',      function(){ getAudioCtx(); }, { once: true });
document.addEventListener('touchstart', function(){ getAudioCtx(); }, { once: true });

// ── FIREBASE ───────────────────────────────────────────────────
var firebaseConfig = {
