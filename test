<script>
'use strict';

// ── CLOCK ──────────────────────────────────────────────────────
setInterval(function(){
    var el = document.getElementById('live-clock');
    if (el) el.textContent = new Date().toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });
