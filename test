// ── STATE ──────────────────────────────────────────────────────
var menuData      = [];        // full menu from Firebase
var soldOutItems  = {};        // { itemName: true } items marked out-of-stock by POS
var currentCat    = 'Tất cả';
var bannerPlaylist = [];
var bannerIndex   = -1;
var bannerActive  = 1;         // which banner layer is front
var bannerTimer   = null;
var ssPlaylist    = [];
var ssIndex       = -1;
var ssActive      = 1;
var ssTimer       = null;
var ssRunning     = false;

// ── DEFAULT SLIDES ─────────────────────────────────────────────
var DEFAULT_SLIDES = [
    { src:'https://firebasestorage.googleapis.com/v0/b/the-cafe-33.firebasestorage.app/o/1768316658706.jpg?alt=media&token=c8854aaa-6af4-40d7-a5b6-ccdda66e58e8', duration:6000 },
    { src:'https://firebasestorage.googleapis.com/v0/b/the-cafe-33.firebasestorage.app/o/1770299826548.jpg?alt=media&token=c3e3fad2-b9b3-48e8-aad8-bd5658a3f386', duration:6000 },
    { src:'https://firebasestorage.googleapis.com/v0/b/the-cafe-33.firebasestorage.app/o/IMG_20260113_214718.png?alt=media&token=7cda9538-ce16-43ae-92a1-7eeaf1166d23', duration:6000 },
    { src:'https://firebasestorage.googleapis.com/v0/b/the-cafe-33.firebasestorage.app/o/%C4%90%E1%BB%8F%20Cam%20Xanh%20L%C3%A1%20R%E1%BB%B1c%20R%E1%BB%A1%20H%C3%ACnh%20%E1%BA%A2nh%20%C4%90%E1%BB%93%20%C4%82n%20Th%E1%BB%A9c%20U%E1%BB%91ng%20B%E1%BB%AFa%20S%C3%A1ng%20Poster_20260122_230631_0000.png?alt=media&token=701bbd64-0618-49fa-bda6-affe536ecdbb', duration:6000 },
    { src:'https://firebasestorage.googleapis.com/v0/b/the-cafe-33.firebasestorage.app/o/IMG_20260113_145355.png?alt=media&token=bf813553-a32c-4e0b-bd39-27e3a283b990', duration:6000 }
];

// ── MENU RENDER ────────────────────────────────────────────────
function getCats() {
    var cats = ['Tất cả'];
    menuData.forEach(function(m){ if (m.type && cats.indexOf(m.type) < 0) cats.push(m.type); });
    return cats;
}

function renderCatBar() {
    var bar = document.getElementById('cat-bar');
    bar.innerHTML = '';
    getCats().forEach(function(cat){
        var btn = document.createElement('button');
        btn.className = 'cat-btn' + (cat === currentCat ? ' active' : '');
        btn.textContent = cat;
        btn.onclick = function(){ currentCat = cat; renderCatBar(); renderMenuGrid(); };
        bar.appendChild(btn);
    });
}

function emoji(type) {
    var map = { 'cà phê':'☕', 'coffee':'☕', 'trà':'🍵', 'nước':'🥤', 'sinh tố':'🥤', 'ăn vặt':'🍟', 'ăn':'🍜', 'bánh':'🍰', 'kem':'🍦', 'trà sữa':'🧋' };
    var t = (type || '').toLowerCase();
    for (var k in map) { if (t.includes(k)) return map[k]; }
    return '🍽️';
}

function renderMenuGrid() {
    var grid = document.getElementById('menu-grid');
    var filtered = currentCat === 'Tất cả'
        ? menuData
        : menuData.filter(function(m){ return m.type === currentCat; });

    // Hide sold-out items
    filtered = filtered.filter(function(m){ return !soldOutItems[m.name]; });

    if (filtered.length === 0) {
        grid.innerHTML = '<div style="grid-column:1/-1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;gap:10px;opacity:0.3;">'
            + '<span class="material-symbols-outlined" style="font-size:2.5rem;">coffee</span>'
            + '<p style="font-size:0.75rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;">Không có món nào</p></div>';
        return;
    }

    grid.innerHTML = filtered.map(function(m, i){
        var isSoldOut  = !!soldOutItems[m.name];
        var hasImg     = m.img && m.img.trim().length > 0;
        var priceM     = m.priceM || 0;
        var priceL     = m.priceL || 0;
        var priceLabel = priceM > 0 ? (priceM/1000)+'k' : (priceL > 0 ? (priceL/1000)+'k' : '···');
        var priceSub   = (priceM > 0 && priceL > 0) ? ' / ' + (priceL/1000) + 'k' : '';
        var cardColor  = m.color || '#006241';
        var delay      = Math.min(i * 40, 400);

        if (hasImg) {
            return '<div class="menu-card" style="animation-delay:' + delay + 'ms;">'
                + (isSoldOut ? '<div class="soldout-overlay"><span>🚫</span><p>Tạm Hết</p></div>' : '')
                + '<img class="card-img" src="' + m.img + '" alt="' + m.name + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'
                + '<div class="card-img-placeholder" style="display:none;background:' + cardColor + '20;">' + emoji(m.type) + '</div>'
                + '<div class="card-body">'
                +   '<div class="card-name">' + m.name + '</div>'
                +   '<div class="card-price">' + priceLabel + (priceSub ? '<span style="font-size:0.65rem;opacity:0.65;">' + priceSub + '</span>' : '') + '</div>'
                + '</div>'
                + '</div>';
        } else {
            return '<div class="menu-card color-card" style="background:' + cardColor + ';animation-delay:' + delay + 'ms;">'
                + (isSoldOut ? '<div class="soldout-overlay"><span>🚫</span><p>Tạm Hết</p></div>' : '')
                + '<div class="card-body">'
                +   '<div style="font-size:1.6rem;margin-bottom:6px;">' + emoji(m.type) + '</div>'
                +   '<div class="card-name" style="color:rgba(255,255,255,0.95);">' + m.name + '</div>'
                +   '<div class="card-price" style="color:rgba(255,255,255,0.85);">' + priceLabel + (priceSub ? '<span style="font-size:0.65rem;opacity:0.7;">' + priceSub + '</span>' : '') + '</div>'
                + '</div>'
                + '</div>';
        }
    }).join('');
}

// ── BANNER SLIDESHOW (right panel top) ────────────────────────
function initBannerDots(count) {
    var dots = document.getElementById('banner-dots');
    dots.innerHTML = '';
    for (var i = 0; i < count; i++) {
        var d = document.createElement('div');
        d.className = 'banner-dot' + (i === 0 ? ' active' : '');
        dots.appendChild(d);
    }
}
function updateBannerDot(idx) {
    var dots = document.querySelectorAll('.banner-dot');
    dots.forEach(function(d, i){ d.classList.toggle('active', i === idx); });
}

function startBanner(slides) {
    bannerPlaylist = slides && slides.length > 0 ? slides : DEFAULT_SLIDES.slice();
    bannerIndex = -1;
    initBannerDots(bannerPlaylist.length);
    nextBannerSlide();
}
function nextBannerSlide() {
    clearTimeout(bannerTimer);
    bannerIndex = (bannerIndex + 1) % bannerPlaylist.length;
    updateBannerDot(bannerIndex);
    var item     = bannerPlaylist[bannerIndex];
    var backId   = bannerActive === 1 ? 'banner-layer-2' : 'banner-layer-1';
    var frontId  = bannerActive === 1 ? 'banner-layer-1' : 'banner-layer-2';
    var backEl   = document.getElementById(backId);
    var frontEl  = document.getElementById(frontId);

    backEl.innerHTML = '';
    var el = document.createElement('img');
    el.src = item.src;
    el.style.cssText = 'width:100%;height:100%;object-fit:cover;';
    el.onload = function(){
        backEl.classList.add('active');
        setTimeout(function(){
            frontEl.classList.remove('active');
            setTimeout(function(){ frontEl.innerHTML = ''; }, 1200);
        }, 100);
        bannerActive = bannerActive === 1 ? 2 : 1;
        bannerTimer = setTimeout(nextBannerSlide, item.duration || 6000);
    };
    el.onerror = function(){ setTimeout(nextBannerSlide, 1000); };
    backEl.appendChild(el);
}

// ── SCREENSAVER ────────────────────────────────────────────────
function startScreensaver() {
    if (ssRunning) return;
    ssRunning = true;
    var ss = document.getElementById('screensaver');
    ss.classList.add('active');
    ss.style.display = 'block';
    ssIndex = -1;
    nextSsSlide();
}
function stopScreensaver() {
    ssRunning = false;
    clearTimeout(ssTimer);
    var ss = document.getElementById('screensaver');
    ss.classList.remove('active');
    ss.style.display = 'none';
    ['ss-layer-1','ss-layer-2'].forEach(function(id){
        var el = document.getElementById(id);
        el.classList.remove('active');
        el.innerHTML = '';
    });
}
function nextSsSlide() {
    if (!ssRunning) return;
    var slides = ssPlaylist.length > 0 ? ssPlaylist : DEFAULT_SLIDES;
    ssIndex = (ssIndex + 1) % slides.length;
    var item   = slides[ssIndex];
    var backId  = ssActive === 1 ? 'ss-layer-2' : 'ss-layer-1';
    var frontId = ssActive === 1 ? 'ss-layer-1' : 'ss-layer-2';
    var backEl  = document.getElementById(backId);
    var frontEl = document.getElementById(frontId);

    backEl.innerHTML = '';
    var el = document.createElement('img');
    el.src = item.src;
    el.style.cssText = 'width:100%;height:100%;object-fit:cover;';
    el.onload = function(){
        if (!ssRunning) return;
        backEl.classList.add('active');
        setTimeout(function(){
            frontEl.classList.remove('active');
            setTimeout(function(){ frontEl.innerHTML = ''; }, 1200);
        }, 100);
        ssActive = ssActive === 1 ? 2 : 1;
        ssTimer = setTimeout(nextSsSlide, item.duration || 6000);
    };
    el.onerror = function(){ setTimeout(nextSsSlide, 1000); };
    backEl.appendChild(el);
}

// ── CART RENDER ────────────────────────────────────────────────
function renderCart(data) {
    var listEl   = document.getElementById('cart-list');
    var emptyEl  = document.getElementById('cart-empty');
    var totalEl  = document.getElementById('total-amount');
    var cashInfo = document.getElementById('cash-info');

    totalEl.textContent = Number(data.total || 0).toLocaleString('vi-VN') + 'đ';

    if (data.state !== 'cash_payment') cashInfo.style.display = 'none';

    if (!data.cart || data.cart.length === 0) {
        emptyEl.style.display = 'flex';
        listEl.innerHTML = '';
        return;
    }
    emptyEl.style.display = 'none';
    listEl.innerHTML = data.cart.map(function(item){
        var sizeBadge = item.size ? '<span style="font-size:0.6rem;font-weight:700;background:#e5e7eb;color:#6b7280;padding:1px 6px;border-radius:4px;margin-left:4px;vertical-align:middle;">' + item.size + '</span>' : '';
        return '<div class="cart-row">'
            + '<div class="cart-qty">' + item.qty + '</div>'
            + '<div class="cart-name">' + item.name + sizeBadge + '</div>'
            + '<div class="cart-item-price">' + Number(item.price * item.qty).toLocaleString('vi-VN') + 'đ</div>'
            + '</div>';
    }).join('');
}

// ── CUSTOMER INFO ──────────────────────────────────────────────
function showCustomer(name, points) {
    var welcome  = document.getElementById('welcome-msg');
    var custInfo = document.getElementById('cust-info');
    welcome.style.display = 'none';
    custInfo.style.display = 'flex';
    document.getElementById('cust-name').textContent   = name;
    document.getElementById('cust-points').textContent = points || 0;
}
function hideCustomer() {
    document.getElementById('welcome-msg').style.display = 'flex';
    document.getElementById('cust-info').style.display   = 'none';
}

// ── RESET ─────────────────────────────────────────────────────
function resetScreen() {
    document.getElementById('view-qr').classList.remove('active');
    document.getElementById('view-success').classList.remove('active');
    hideCustomer();
    document.getElementById('total-amount').textContent = '0đ';
    document.getElementById('cash-info').style.display = 'none';
    document.getElementById('cart-list').innerHTML = '';
    document.getElementById('cart-empty').style.display = 'flex';
    closePhoneInput();
    startScreensaver();
}

// ── SUCCESS ────────────────────────────────────────────────────
function showSuccess(data) {
    var sv = document.getElementById('view-success');
    sv.classList.add('active');
    playSound('success');
    setTimeout(function(){ sv.classList.remove('active'); resetScreen(); }, 5000);
}

// ── PHONE INPUT ────────────────────────────────────────────────
function openPhoneInput() {
    stopScreensaver();
    var v = document.getElementById('view-phone');
    v.classList.add('active');
    var inp = document.getElementById('native-phone');
    inp.value = '';
    setTimeout(function(){ inp.focus(); }, 100);
    playSound('notify');
}
function closePhoneInput() {
    document.getElementById('view-phone').classList.remove('active');
    document.getElementById('native-phone').blur();
}
function submitPhone() {
    var val = document.getElementById('native-phone').value.trim();
    if (val.length < 3) return;
    var btn = document.getElementById('btn-submit-phone');
    btn.textContent = 'Đang gửi...'; btn.style.opacity = '0.5';
    db.ref('client_input').set({ type:'phone_update', value: val, timestamp: Date.now() })
        .then(function(){
            btn.textContent = '✔ Đã gửi';
            setTimeout(function(){
                closePhoneInput();
                btn.textContent = 'Gửi Ngay'; btn.style.opacity = '';
            }, 600);
        })
        .catch(function(e){
            alert('Lỗi: ' + e.message);
            btn.textContent = 'Gửi lại'; btn.style.opacity = '';
        });
}
document.getElementById('native-phone').addEventListener('keypress', function(e){ if(e.key==='Enter') submitPhone(); });

// ── ZOOM ───────────────────────────────────────────────────────
function closeZoom() { document.getElementById('image-viewer').style.display = 'none'; }

// ── SOLD OUT SYNC ──────────────────────────────────────────────
// Listen to POS-pushed soldout list from Firebase RTDB
function listenSoldOut() {
    db.ref('screen_soldout').on('value', function(snap){
        soldOutItems = snap.val() || {};
        renderMenuGrid();
    });
}

// ── FIREBASE LISTENERS ─────────────────────────────────────────
function listenMenu() {
    db.ref('menu').on('value', function(snap){
        var data = snap.val();
        if (data) {
            menuData = Array.isArray(data) ? data : Object.values(data);
        } else {
            menuData = [];
        }
        renderCatBar();
        renderMenuGrid();
    });
}

function listenSlides() {
    fstore.collection('config').doc('screen_slides').onSnapshot(function(doc){
        var arr = doc.exists ? doc.data().slides : null;
        var slides = (arr && arr.length > 0)
            ? arr.map(function(s){ return { src: s.url, duration: (s.duration||6)*1000 }; })
            : DEFAULT_SLIDES.slice();
        ssPlaylist  = slides;
        startBanner(slides);
    }, function(){ startBanner(DEFAULT_SLIDES.slice()); });
}

function listenPOS() {
    db.ref('session_display').on('value', function(snap){
        var data = snap.val();
        if (!data || data.state === 'idle') { resetScreen(); return; }

        if (data.state === 'input_phone') { stopScreensaver(); openPhoneInput(); return; }

        if (data.state === 'qr_payment') {
            stopScreensaver();
            document.getElementById('view-qr').classList.add('active');
            document.getElementById('qr-image').src = data.qrUrl || '';
            document.getElementById('qr-amount').textContent = Number(data.amount||0).toLocaleString('vi-VN') + 'đ';
            return;
        }

        if (data.state === 'success') {
            stopScreensaver();
            document.getElementById('view-qr').classList.remove('active');
            showSuccess(data); return;
        }

        if (data.state === 'cash_payment') {
            stopScreensaver();
            document.getElementById('view-qr').classList.remove('active');
            document.getElementById('view-success').classList.remove('active');
            renderCart(data);
            var paid   = Number(data.paid   || 0);
            var change = Number(data.change || 0);
            document.getElementById('screen-paid').textContent   = paid.toLocaleString('vi-VN') + 'đ';
            document.getElementById('screen-change').textContent = (change > 0 ? change : 0).toLocaleString('vi-VN') + 'đ';
            document.getElementById('screen-change').style.color = change > 0 ? 'var(--amber)' : 'var(--muted)';
            document.getElementById('cash-info').style.display = 'flex';
            if (data.customerName && data.customerName !== 'Khách mới' && data.customerName !== 'Khách lẻ') {
                showCustomer(data.customerName, data.customerPoints || 0);
            }
            return;
        }

        // Default: show cart
        stopScreensaver();
        document.getElementById('view-qr').classList.remove('active');
        document.getElementById('view-success').classList.remove('active');
        renderCart(data);

        if (data.customerName && data.customerName !== 'Khách mới' && data.customerName !== 'Khách lẻ') {
            showCustomer(data.customerName, data.customerPoints || 0);
        } else {
            hideCustomer();
        }
    });
}

// ── BOOT ──────────────────────────────────────────────────────
auth.signInWithEmailAndPassword("elio@thecafe33.com", "Thecafe33ty")
    .then(function(){
        console.log("Screen connected ✓");
        listenMenu();
        listenSlides();
        listenPOS();
        listenSoldOut();
    })
    .catch(function(e){ console.error("Auth error:", e); });

// Start screensaver immediately while loading
startScreensaver();

</script>

